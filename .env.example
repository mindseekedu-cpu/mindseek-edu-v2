# ============================================
# MindSeek.edu - Environment Variables
# ============================================

# DeepSeek API Key
# Dapatkan dari platform DeepSeek (https://platform.deepseek.com/)
# Digunakan untuk AI chat dan evaluasi pembelajaran
DEEPSEEK_API_KEY=

# Supabase Configuration
# Dapatkan dari dashboard Supabase project Anda > Project Settings > API
# URL: Project URL (misal: https://xxxxx.supabase.co)
SUPABASE_URL=

# Supabase Anon/Public Key (bukan service_role key)
# Dapatkan dari dashboard Supabase > Project Settings > API > Project API keys
SUPABASE_ANON_KEY=

# OCR Space API Key
# Dapatkan dari https://ocr.space/ (gratis tier tersedia)
# Digunakan untuk memproses hasil scan/tulisan tangan siswa
OCR_SPACE_API_KEY=
